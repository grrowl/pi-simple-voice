{
  "name": "pi-simple-voice",
  "version": "0.1.0",
  "description": "Streaming, verbatim Kokoro TTS for the Pi agent — speaks the assistant's output as it streams, no summarization.",
  "type": "module",
  "license": "MIT",
  "author": "grrowl",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "tts",
    "kokoro",
    "speech-synthesis",
    "streaming"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/grrowl/pi-simple-voice"
  },
  "bin": {
    "pi-simple-voice": "./src/cli.ts"
  },
  "files": [
    "extensions",
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "!.github"
  ],
  "pi": {
    "extensions": [
      "./extensions/index.ts"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "cli": "node --import jiti src/cli.ts",
    "server": "node --import jiti extensions/server.ts",
    "prepare": "node --import jiti src/prepare.js"
  },
  "dependencies": {
    "jiti": "^2.4.2",
    "kokoro-js": "^1.2.1"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@earendil-works/pi-coding-agent": "*",
    "typescript": "^5.0.0"
  }
}
