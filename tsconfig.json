{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    // pi/bun load .ts directly, so relative imports keep their .ts extension.
    "allowImportingTsExtensions": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "noEmit": true
  },
  "include": ["extensions/**/*.ts", "src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
